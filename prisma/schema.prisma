generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  role            RoleType
  password        String
  attendances     Attendance[]
  auditLogs       AuditLog[]
  employeeProfile EmployeeProfile?
  leaveRequests   LeaveRequest[]
}

model EmployeeProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  workPolicyId   String
  shiftId        String?
  employmentType EmploymentType @default(FULLTIME)
  shift          Shift?         @relation(fields: [shiftId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  workPolicy     WorkPolicy     @relation(fields: [workPolicyId], references: [id])
  shift          Shift?         @relation(fields: [shiftId], references: [id])
}

enum EmploymentType {
  FULLTIME
  PARTTIME
}

model WorkPolicy {
  id                         String            @id @default(uuid())
  name                       String
  startTime                  DateTime
  endTime                    DateTime
  allowedLateMinutesPerMonth Int
  deductIfLateOver           Int               @default(0)
  minHoursForHalfDay         Int
  halfDayAbsentRule          Int
  remark                     String?
  attendances                Attendance[]
  employeeProfiles           EmployeeProfile[]
}

model Shift {
  id               String            @id @default(uuid())
  name             String
  inTime           DateTime
  outTime          DateTime
  attendances      Attendance[]
  employeeProfiles EmployeeProfile[]
}

model Attendance {
  id               String            @id @default(uuid())
  userId           String
  date             DateTime
  clockIn          DateTime?
  clockOut         DateTime?
  isLate           Boolean           @default(false)
  lateMinutes      Int               @default(0)
  isAbsent         Boolean           @default(false)
  totalHours       Float             @default(0)
  overtimeHours    Float             @default(0)
  status           StatusType        @default(PENDING)
  workPolicyId     String
  shiftId          String
  shift            Shift             @relation(fields: [shiftId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  workPolicy       WorkPolicy        @relation(fields: [workPolicyId], references: [id])
  leaveAdjustments LeaveAdjustment[]
}

enum StatusType {
  PENDING
  ABSENT
  ON_LEAVE
  COMPLETED
  INCOMPLETED
}

model LeaveRequest {
  id          String            @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  leaveType   LeaveType
  status      StatusLeave       @default(PENDING)
  reason      String
  userId      String
  adjustments LeaveAdjustment[]
  user        User              @relation(fields: [userId], references: [id])
  adjustments LeaveAdjustment[]
}

enum LeaveType {
  SICK
  PERSONAL
  VACATION
  UNPAID
  MATERNITY
}

enum StatusLeave {
  APPROVED
  REJECTED
  PENDING
}

model LeaveAdjustment {
  id               String       @id @default(uuid())
  leaveRequestId   String
  deductionMinutes Int
  adjustmentType   String
  attendanceId     String
  attendance       Attendance   @relation(fields: [attendanceId], references: [id])
  leaveRequest     LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  attendance       Attendance   @relation(fields: [attendanceId], references: [id])
}

model Holiday {
  id   String   @id @default(uuid())
  date DateTime
  name String
}

model AuditLog {
  id           String    @id @default(uuid())
  action       LogAction
  relatedTable String
  relatedId    String
  detail       String
  createdAt    DateTime  @default(now())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}
