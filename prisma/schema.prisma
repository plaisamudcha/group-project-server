generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  name                    String
  email                   String                   @unique
  role                    RoleType
  password                String
  annualLeaveEntitlements AnnualLeaveEntitlement[]
  attendances             Attendance[]
  auditLogs               AuditLog[]
  employeeProfile         EmployeeProfile?
  leaveRequests           LeaveRequest[]
}

model EmployeeProfile {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique
  workPolicyId   Int
  shiftId        Int?
  employmentType EmploymentType @default(FULLTIME)
  shift          Shift?         @relation(fields: [shiftId], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workPolicy     WorkPolicy     @relation(fields: [workPolicyId], references: [id])

  @@index([shiftId], map: "EmployeeProfile_shiftId_fkey")
  @@index([workPolicyId], map: "EmployeeProfile_workPolicyId_fkey")
}

model WorkPolicy {
  id                         Int               @id @default(autoincrement())
  name                       String
  startTime                  DateTime
  endTime                    DateTime
  allowedLateMinutesPerMonth Int
  deductIfLateOver           Int               @default(0)
  minHoursForHalfDay         Int
  halfDayAbsentRule          Float
  remark                     String?
  attendances                Attendance[]
  employeeProfiles           EmployeeProfile[]
}

model Shift {
  id               Int               @id @default(autoincrement())
  name             String
  inTime           DateTime
  outTime          DateTime
  attendances      Attendance[]
  employeeProfiles EmployeeProfile[]
}

model Attendance {
  id               Int               @id @default(autoincrement())
  userId           Int
  date             DateTime
  clockIn          DateTime?
  clockOut         DateTime?
  isLate           Boolean           @default(false)
  lateMinutes      Int               @default(0)
  isAbsent         Boolean           @default(false)
  totalHours       Float             @default(0)
  overtimeHours    Float             @default(0)
  status           StatusType        @default(PENDING)
  workPolicyId     Int
  shiftId          Int?
  shift            Shift?            @relation(fields: [shiftId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  workPolicy       WorkPolicy        @relation(fields: [workPolicyId], references: [id])
  leaveAdjustments LeaveAdjustment[]

  @@index([shiftId], map: "Attendance_shiftId_fkey")
  @@index([userId], map: "Attendance_userId_fkey")
  @@index([workPolicyId], map: "Attendance_workPolicyId_fkey")
}

model LeaveRequest {
  id          Int               @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime
  leaveDays   Float
  createdAt   DateTime          @default(now())
  updateAt    DateTime?         @updatedAt
  leaveType   LeaveType
  status      StatusLeave       @default(PENDING)
  reason      String
  userId      Int
  adjustments LeaveAdjustment[]
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId], map: "LeaveRequest_userId_fkey")
}

model LeaveAdjustment {
  id               Int          @id @default(autoincrement())
  leaveRequestId   Int
  deductionMinutes Int
  adjustmentType   StatusType
  attendanceId     Int
  attendance       Attendance   @relation(fields: [attendanceId], references: [id])
  leaveRequest     LeaveRequest @relation(fields: [leaveRequestId], references: [id])

  @@index([attendanceId], map: "LeaveAdjustment_attendanceId_fkey")
  @@index([leaveRequestId], map: "LeaveAdjustment_leaveRequestId_fkey")
}

model Holiday {
  id   Int      @id @default(autoincrement())
  date DateTime
  name String
}

model AuditLog {
  id           Int       @id @default(autoincrement())
  action       LogAction
  relatedTable String
  relatedId    Int
  detail       String
  createdAt    DateTime  @default(now())
  userId       Int
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId], map: "AuditLog_userId_fkey")
}

model AnnualLeaveEntitlement {
  id            Int       @id @default(autoincrement())
  userId        Int
  year          Int
  leaveType     LeaveType
  entitledDays  Float
  usedDays      Float     @default(0)
  remainingDays Float
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId], map: "AnnualLeaveEntitlement_userId_fkey")
}

enum EmploymentType {
  FULLTIME
  PARTTIME
}

enum StatusType {
  PENDING
  ABSENT
  ON_LEAVE
  COMPLETED
  INCOMPLETED
}

enum LeaveType {
  SICK
  PERSONAL
  VACATION
  UNPAID
  MATERNITY
}

enum StatusLeave {
  APPROVED
  REJECTED
  PENDING
}

enum RoleType {
  EMPLOYEE
  HR
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}
